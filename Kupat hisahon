<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>קופת החיסכון שלי</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Assistant', sans-serif;
        }
        /* הסרת חיצים משדה מספר */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen p-4 md:p-8">

    <div class="max-w-md mx-auto space-y-6">
        
        <!-- כרטיס יתרה -->
        <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-3xl p-8 text-white shadow-xl relative overflow-hidden">
            <div class="relative z-10">
                <h1 class="text-xl opacity-90 mb-2 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 5c-1.5 0-2.8 1.4-3 2-3.5-1.5-11-.3-11 5 0 1.8 0 3 2 4.5V20h4v-2h3v2h4v-4c1-.5 1.7-1 2-2h2v-4h-2c0-1-.5-1.5-1-2h0V5z"/><path d="M7 11h.01"/><path d="M11 11h.01"/><path d="M15 11h.01"/></svg>
                    הקופה שלי
                </h1>
                <div id="balance-display" class="text-5xl font-bold tracking-tight">
                    ₪0.00
                </div>
                <p class="mt-4 text-blue-100 text-sm flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    החיסכון שלך גדל!
                </p>
            </div>
            <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-white opacity-10 rounded-full"></div>
        </div>

        <!-- טופס עדכון -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <h2 class="text-lg font-bold mb-4 text-slate-800">עדכון יתרה</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm text-slate-500 mb-1">סכום בשקלים</label>
                    <input
                        id="amount-input"
                        type="number"
                        step="0.1"
                        placeholder="0.00"
                        class="w-full text-2xl font-semibold p-3 border-b-2 border-slate-200 focus:border-blue-500 outline-none transition-colors"
                    />
                </div>
                <div>
                    <label class="block text-sm text-slate-500 mb-1">הערה (אופציונלי)</label>
                    <input
                        id="note-input"
                        type="text"
                        placeholder="למשל: דמי כיס, מתנה מסבתא..."
                        class="w-full p-2 bg-slate-50 rounded-lg border border-slate-100 outline-none focus:ring-1 ring-blue-200"
                    />
                </div>
                <div class="flex gap-3">
                    <button
                        onclick="updateBalance('deposit')"
                        class="flex-1 bg-green-500 hover:bg-green-600 text-white font-bold py-3 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 shadow-md shadow-green-100"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                        הוספה
                    </button>
                    <button
                        onclick="updateBalance('withdrawal')"
                        class="flex-1 bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 shadow-md shadow-red-100"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                        הורדה
                    </button>
                </div>
            </div>
        </div>

        <!-- היסטוריה -->
        <div class="space-y-3">
            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 px-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                פעולות אחרונות
            </h2>
            <div id="transactions-list" class="space-y-2">
                <!-- הפעולות יופיעו כאן -->
            </div>
            
            <!-- כפתור איפוס נתונים -->
            <button onclick="confirmReset()" class="w-full mt-8 text-xs text-slate-400 hover:text-red-400 transition-colors py-4">
                איפוס כל הנתונים והתחלה מחדש
            </button>
        </div>

        <!-- הודעת שגיאה מותאמת -->
        <div id="error-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
            <div class="bg-white p-6 rounded-2xl max-w-xs w-full text-center space-y-4 shadow-2xl">
                <div class="text-red-500 flex justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-800">אופס!</h3>
                <p id="error-message" class="text-slate-600">אין מספיק כסף בקופה.</p>
                <button onclick="closeModal()" class="w-full bg-slate-800 text-white py-2 rounded-lg font-bold">סגור</button>
            </div>
        </div>
    </div>

    <script>
        // מפתח לאחסון ב-localStorage
        const STORAGE_KEY_BALANCE = 'piggy_bank_balance';
        const STORAGE_KEY_TRANSACTIONS = 'piggy_bank_transactions';

        // אתחול המצב מהזיכרון המקומי או ערכי ברירת מחדל
        let balance = parseFloat(localStorage.getItem(STORAGE_KEY_BALANCE)) || 186.7;
        let transactions = JSON.parse(localStorage.getItem(STORAGE_KEY_TRANSACTIONS)) || [
            { id: 1, amount: 186.7, type: 'deposit', note: 'יתרה ראשונית', date: new Date().toLocaleString('he-IL') }
        ];

        // פונקציה לשמירת נתונים בזיכרון המקומי
        function saveData() {
            localStorage.setItem(STORAGE_KEY_BALANCE, balance.toString());
            localStorage.setItem(STORAGE_KEY_TRANSACTIONS, JSON.stringify(transactions));
        }

        // פונקציה לעדכון התצוגה
        function render() {
            // עדכון היתרה
            document.getElementById('balance-display').innerText = `₪${balance.toLocaleString('he-IL', { minimumFractionDigits: 2 })}`;

            // עדכון רשימת הפעולות
            const list = document.getElementById('transactions-list');
            list.innerHTML = '';

            transactions.forEach(t => {
                const item = document.createElement('div');
                item.className = 'bg-white p-4 rounded-xl shadow-sm border border-slate-50 flex items-center justify-between transition-all hover:bg-slate-50';
                
                const isDeposit = t.type === 'deposit';
                const iconColor = isDeposit ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600';
                const textColor = isDeposit ? 'text-green-600' : 'text-red-600';
                const symbol = isDeposit ? '+' : '-';
                const icon = isDeposit 
                    ? `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>`
                    : `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>`;

                item.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="p-2 rounded-full ${iconColor}">
                            ${icon}
                        </div>
                        <div>
                            <div class="font-bold text-slate-800">${t.note}</div>
                            <div class="text-xs text-slate-400">${t.date}</div>
                        </div>
                    </div>
                    <div class="text-lg font-bold ${textColor}">
                        ${symbol} ₪${t.amount.toLocaleString()}
                    </div>
                `;
                list.appendChild(item);
            });
        }

        // פונקציה להוספה או משיכה
        function updateBalance(type) {
            const amountInput = document.getElementById('amount-input');
            const noteInput = document.getElementById('note-input');
            const amountValue = amountInput.value.trim();
            const amount = parseFloat(amountValue);
            const note = noteInput.value.trim();

            if (isNaN(amount) || amount <= 0) return;

            if (type === 'withdrawal' && amount > balance) {
                showModal('אין מספיק כסף בקופה!');
                return;
            }

            const newTransaction = {
                id: Date.now(),
                amount: amount,
                type: type,
                note: note || (type === 'deposit' ? 'הפקדה' : 'משיכה'),
                date: new Date().toLocaleString('he-IL')
            };

            if (type === 'deposit') {
                balance += amount;
            } else {
                balance -= amount;
            }

            transactions.unshift(newTransaction);
            
            // איפוס קלט
            amountInput.value = '';
            noteInput.value = '';
            
            saveData();
            render();
        }

        // פונקציית איפוס
        function confirmReset() {
            if (confirm('האם אתה בטוח שברצונך לאפס את כל נתוני הקופה? פעולה זו אינה ניתנת לביטול.')) {
                balance = 186.7;
                transactions = [
                    { id: 1, amount: 186.7, type: 'deposit', note: 'יתרה ראשונית', date: new Date().toLocaleString('he-IL') }
                ];
                saveData();
                render();
            }
        }

        // ניהול הודעות שגיאה
        function showModal(msg) {
            document.getElementById('error-message').innerText = msg;
            document.getElementById('error-modal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('error-modal').classList.add('hidden');
        }

        // הרצה ראשונית
        window.onload = render;
    </script>
</body>
</html>
